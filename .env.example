# Discord bot token (from Discord Developer Portal)
DISCORD_BOT_TOKEN=your_discord_bot_token

# SFDX Auth URLs — get these by running:
#   sf org display --target-org <alias> --verbose
# and copying the "Sfdx Auth Url" field (starts with force://)
UAT_SFDX_AUTH_URL=force://CLIENT_ID:CLIENT_SECRET:REFRESH_TOKEN@your-uat.salesforce.com
PROD_SFDX_AUTH_URL=force://CLIENT_ID:CLIENT_SECRET:REFRESH_TOKEN@your-prod.salesforce.com

# Org aliases (used as --target-org values in sf commands)
UAT_SF_ORG_ALIAS=uat
PROD_SF_ORG_ALIAS=prod

# Optional: full path to sf binary if not on PATH
# SF_CLI_PATH=/usr/local/bin/sf
